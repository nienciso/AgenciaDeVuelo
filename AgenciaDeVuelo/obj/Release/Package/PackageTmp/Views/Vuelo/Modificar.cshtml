@{
    ViewBag.Title = "Modificar vuelo";
}

<h2>Modificar vuelo</h2>

<form method="post">
    <label>Código</label>
    <input type="text" name="codigo" class="form-control" maxlength="10" required />

    <br />

    <input type="submit" value="Buscar" class="btn btn-primary" />
</form>

@if (ViewBag.Mensaje != null)
{
    <br />
    <div class="alert alert-info">@ViewBag.Mensaje</div>
}

@if (ViewBag.Vuelo != null)
{
    <hr />

    <form method="post" action="/Vuelo/GuardarModificacion">

        <label>Código</label>
        <input type="text"
               name="codigo"
               value="@ViewBag.Vuelo.Codigo"
               readonly
               class="form-control" />

        <br />

        <label>Fecha/hora partida</label>
        <input type="datetime-local"
               name="fechaHoraPartida"
               value="@ViewBag.Vuelo.FechaHoraPartida.ToString("yyyy-MM-ddTHH:mm")"
               class="form-control"
               required />

        <br />

        <label>Estado partida</label>
        <select name="codigoEstadoPartida" class="form-control" required>
            @foreach (var e in ViewBag.Estados)
            {
                <option value="@e.Codigo" @(e.Codigo == ViewBag.Vuelo.EstadoPartida.Codigo ? "selected" : "")>
                    @e.Nombre - @e.Pais
                </option>
            }
        </select>

        <br />

        <label>Fecha/hora llegada</label>
        <input type="datetime-local"
               name="fechaHoraLlegada"
               value="@ViewBag.Vuelo.FechaHoraLlegada.ToString("yyyy-MM-ddTHH:mm")"
               class="form-control"
               required />

        <br />

        <label>Estado llegada</label>
        <select name="codigoEstadoLlegada" class="form-control" required>
            @foreach (var e in ViewBag.Estados)
            {
                <option value="@e.Codigo" @(e.Codigo == ViewBag.Vuelo.EstadoLlegada.Codigo ? "selected" : "")>
                    @e.Nombre - @e.Pais
                </option>
            }
        </select>

        <br />

        <label>Precio pasaje</label>
        <input type="number"
               name="precioPasaje"
               value="@ViewBag.Vuelo.PrecioPasaje"
               class="form-control"
               min="1"
               step="0.01"
               required />

        <br />

        <label>Activo</label>
        <input type="checkbox"
               name="activo"
               value="true"
               @(ViewBag.Vuelo.Activo ? "checked" : "") />

        <br /><br />

        <input type="submit" value="Guardar cambios" class="btn btn-warning" />
    </form>
}

<br />

@Html.ActionLink("Volver", "Mantenimiento", "Vuelo")